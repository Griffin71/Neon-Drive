# OS
.DS_Store
Thumbs.db

# Track specific file types with Git LFS
git lfs track "*.psd"
git lfs track "*.png"
git lfs track "*.jpg"
git lfs track "*.mp3"
git lfs track "*.wav"
git lfs track "*.fbx"
git lfs track "*.blend"

# This creates/updates .gitattributes
git add .gitattributes