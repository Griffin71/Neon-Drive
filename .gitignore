# Python
__pycache__/
*.py[cod]
*.class
*.so
.Python

# Virtual Environment
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Game saves - hide all contents but keep the folder
saves/*
!saves/.gitkeep

# Assets 
# assets/images/
# assets/sounds/
